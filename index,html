<style>
/* ================= RESET & TOKENS ================= */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
:root{
  --bg:#F7F5F2;
  --bg-deep:#F1EEE8;
  --navy:#0B1F33;
  --navy-soft:#152C45;
  --gold:#C9A96E;
  --gold-soft:#DCC596;
  --slate:#6A7A89;
  --white:#FFFFFF;
  --line:rgba(11,31,51,0.1);
  --serif:'Fraunces', Georgia, serif;
  --sans:'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  --ease:cubic-bezier(.22,1,.36,1);
  --maxw:1240px;
}
html{scroll-behavior:smooth;}
body{
  font-family:var(--sans);
  background:var(--bg);
  color:var(--navy);
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
  line-height:1.6;
}
img{max-width:100%;display:block;}
a{color:inherit;text-decoration:none;}
button{font-family:inherit;border:none;background:none;cursor:pointer;}
ul{list-style:none;}
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 32px;}
.serif{font-family:var(--serif);}
@media(max-width:640px){.wrap{padding:0 22px;}}

::selection{background:var(--gold);color:var(--navy);}

/* reduced motion */
@media (prefers-reduced-motion: reduce){
  *{animation-duration:0.01ms !important;animation-iteration-count:1 !important;transition-duration:0.01ms !important;scroll-behavior:auto !important;}
}

/* focus visibility */
a:focus-visible,button:focus-visible,input:focus-visible,textarea:focus-visible{
  outline:2px solid var(--gold);outline-offset:3px;
}

/* ================= LOADER ================= */
#loader{
  position:fixed;inset:0;background:var(--navy);z-index:9999;
  display:flex;align-items:center;justify-content:center;
  transition:opacity .8s var(--ease), visibility .8s var(--ease);
}
#loader.done{opacity:0;visibility:hidden;}
.loader-mark{width:120px;height:60px;}
.loader-mark path{
  stroke:var(--gold-soft);
  stroke-width:2.4;
  fill:none;
  stroke-linecap:round;
  stroke-dasharray:220;
  stroke-dashoffset:220;
  animation:drawSmile 1.4s var(--ease) forwards;
}
@keyframes drawSmile{to{stroke-dashoffset:0;}}

/* ================= SCROLL PROGRESS ================= */
#scrollbar{
  position:fixed;top:0;left:0;height:3px;background:var(--gold);
  width:0%;z-index:1001;transition:width .1s linear;
}

/* ================= NAV ================= */
header{
  position:fixed;top:0;left:0;right:0;z-index:900;
  background:rgba(247,245,242,0.0);
  backdrop-filter:blur(0px);
  transition:background .4s var(--ease), backdrop-filter .4s var(--ease), box-shadow .4s var(--ease);
  padding:22px 0;
}
header.scrolled{
  background:rgba(247,245,242,0.86);
  backdrop-filter:blur(14px);
  box-shadow:0 1px 0 var(--line);
  padding:14px 0;
}
.nav-row{display:flex;align-items:center;justify-content:space-between;}
.brand{display:flex;align-items:center;gap:10px;font-family:var(--serif);font-size:19px;letter-spacing:.02em;color:var(--navy);}
.brand svg{width:30px;height:30px;flex-shrink:0;}
.brand .bsub{font-family:var(--sans);font-size:10.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--slate);display:block;font-weight:500;}
nav.links{display:flex;gap:38px;align-items:center;}
nav.links a{
  font-size:13.5px;font-weight:500;letter-spacing:.02em;color:var(--navy);
  position:relative;padding:4px 0;
}
nav.links a::after{
  content:'';position:absolute;left:0;bottom:0;width:0;height:1px;background:var(--gold);
  transition:width .35s var(--ease);
}
nav.links a:hover::after{width:100%;}
.nav-cta{
  display:flex;align-items:center;gap:14px;
}
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:8px;
  padding:13px 26px;font-size:13.5px;font-weight:600;letter-spacing:.03em;
  border-radius:2px;white-space:nowrap;position:relative;overflow:hidden;
  transition:transform .35s var(--ease), box-shadow .35s var(--ease);
}
.btn-gold{background:var(--gold);color:var(--navy);}
.btn-gold:hover{box-shadow:0 10px 26px -8px rgba(201,169,110,.7);}
.btn-outline{border:1px solid var(--navy);color:var(--navy);background:transparent;}
.btn-outline:hover{background:var(--navy);color:var(--bg);}
.btn-outline-light{border:1px solid rgba(247,245,242,.5);color:var(--bg);}
.btn-outline-light:hover{background:var(--bg);color:var(--navy);}
.btn.magnetic{will-change:transform;}
.btn small{font-weight:400;opacity:.85;font-size:12px;}

.menu-toggle{display:none;width:26px;height:20px;position:relative;cursor:pointer;z-index:1100;}
.menu-toggle span{position:absolute;left:0;width:100%;height:2px;background:var(--navy);transition:.3s var(--ease);}
.menu-toggle span:nth-child(1){top:0;}
.menu-toggle span:nth-child(2){top:9px;}
.menu-toggle span:nth-child(3){top:18px;}
.menu-toggle.open span:nth-child(1){transform:translateY(9px) rotate(45deg);}
.menu-toggle.open span:nth-child(2){opacity:0;}
.menu-toggle.open span:nth-child(3){transform:translateY(-9px) rotate(-45deg);}

@media(max-width:980px){
  nav.links{display:none;}
  .nav-cta .btn-outline{display:none;}
  .menu-toggle{display:block;}
}

/* mobile drawer */
#drawer{
  position:fixed;inset:0;background:var(--navy);z-index:1050;
  transform:translateX(100%);transition:transform .5s var(--ease);
  display:flex;flex-direction:column;justify-content:center;padding:40px;
}
#drawer.open{transform:translateX(0);}
#drawer a{
  color:var(--bg);font-family:var(--serif);font-size:30px;padding:16px 0;
  border-bottom:1px solid rgba(247,245,242,.12);
}
#drawer .drawer-cta{margin-top:30px;}

/* ================= SECTION SHARED ================= */
section{position:relative;}
.eyebrow{
  font-size:12px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;
  color:var(--gold);display:flex;align-items:center;gap:10px;margin-bottom:18px;
}
.eyebrow::before{content:'';width:26px;height:1px;background:var(--gold);}
h1,h2,h3{font-family:var(--serif);font-weight:500;color:var(--navy);line-height:1.08;}
h2{font-size:clamp(32px,4.6vw,52px);letter-spacing:-.01em;}
h3{font-size:22px;}
p.lead{font-size:17px;color:var(--slate);max-width:560px;line-height:1.7;}
.section-head{margin-bottom:60px;}
.section-pad{padding:120px 0;}
@media(max-width:780px){.section-pad{padding:80px 0;}.section-head{margin-bottom:44px;}}

.reveal{opacity:0;transform:translateY(34px);transition:opacity .9s var(--ease), transform .9s var(--ease);}
.reveal.in{opacity:1;transform:translateY(0);}
.reveal-stagger > *{opacity:0;transform:translateY(28px);transition:opacity .8s var(--ease), transform .8s var(--ease);}
.reveal-stagger.in > *{opacity:1;transform:translateY(0);}
.reveal-stagger.in > *:nth-child(1){transition-delay:.05s;}
.reveal-stagger.in > *:nth-child(2){transition-delay:.15s;}
.reveal-stagger.in > *:nth-child(3){transition-delay:.25s;}
.reveal-stagger.in > *:nth-child(4){transition-delay:.35s;}
.reveal-stagger.in > *:nth-child(5){transition-delay:.45s;}

/* ================= HERO ================= */
#hero{
  min-height:100vh;display:flex;align-items:center;
  padding:140px 0 80px;
  background:
    radial-gradient(ellipse 900px 600px at 85% -10%, rgba(201,169,110,0.16), transparent 60%),
    var(--bg);
  overflow:hidden;
}
.hero-grid{
  display:grid;grid-template-columns:1.05fr .95fr;gap:60px;align-items:center;position:relative;
}
.hero-copy .eyebrow{margin-bottom:22px;}
.hero-copy h1{font-size:clamp(38px,5.6vw,68px);letter-spacing:-0.015em;margin-bottom:24px;}
.hero-copy h1 em{font-style:italic;color:var(--gold);font-weight:400;}
.hero-copy p.lead{margin-bottom:38px;font-size:18px;}
.hero-ctas{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:46px;}
.hero-trust{display:flex;gap:30px;flex-wrap:wrap;}
.hero-trust div{font-size:12.5px;color:var(--slate);display:flex;flex-direction:column;gap:3px;}
.hero-trust strong{font-family:var(--serif);font-size:24px;color:var(--navy);font-weight:500;}

.hero-visual{position:relative;display:flex;justify-content:center;}
.hero-frame{
  position:relative;width:100%;max-width:420px;aspect-ratio:4/5;
  border-radius:4px;overflow:hidden;
  box-shadow:0 40px 80px -30px rgba(11,31,51,.35);
}
.hero-frame img{width:100%;height:100%;object-fit:cover;}
.hero-frame::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(180deg, transparent 60%, rgba(11,31,51,.55));
}
.hero-frame-caption{
  position:absolute;bottom:22px;left:22px;right:22px;color:#fff;z-index:2;
}
.hero-frame-caption .name{font-family:var(--serif);font-size:19px;}
.hero-frame-caption .role{font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--gold-soft);margin-top:4px;}

.hero-frame-outline{
  position:absolute;top:-18px;left:-18px;right:18px;bottom:18px;
  border:1px solid var(--gold);border-radius:4px;z-index:-1;
}
.float-badge{
  position:absolute;background:#fff;border-radius:3px;
  box-shadow:0 18px 40px -16px rgba(11,31,51,.25);
  padding:14px 18px;display:flex;align-items:center;gap:10px;
  animation:floaty 5s ease-in-out infinite;
}
.float-badge svg{width:22px;height:22px;flex-shrink:0;}
.float-badge .fb-title{font-size:12.5px;font-weight:600;color:var(--navy);}
.float-badge .fb-sub{font-size:10.5px;color:var(--slate);}
.fb1{top:8%;left:-10%;animation-delay:0s;}
.fb2{bottom:10%;right:-8%;animation-delay:1.4s;}
@keyframes floaty{0%,100%{transform:translateY(0);}50%{transform:translateY(-12px);}}
@media(max-width:980px){
  .float-badge{display:none;}
}

@media(max-width:980px){
  .hero-grid{grid-template-columns:1fr;gap:48px;}
  .hero-visual{order:-1;}
  .hero-frame{max-width:320px;margin:0 auto;}
}

.smile-deco{position:absolute;pointer-events:none;}
.smile-deco svg{width:100%;height:100%;}
.deco-1{top:6%;left:-6%;width:280px;opacity:.5;animation:drift 14s ease-in-out infinite;}
.deco-2{bottom:-4%;right:-4%;width:220px;opacity:.4;animation:drift 18s ease-in-out infinite reverse;}
@keyframes drift{0%,100%{transform:translate(0,0) rotate(0deg);}50%{transform:translate(14px,-10px) rotate(3deg);}}

.scroll-cue{
  position:absolute;bottom:36px;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:8px;
  font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--slate);
}
.scroll-cue .line{width:1px;height:34px;background:linear-gradient(var(--slate),transparent);animation:scrollline 2s ease-in-out infinite;}
@keyframes scrollline{0%{transform:scaleY(0);transform-origin:top;}50%{transform:scaleY(1);transform-origin:top;}51%{transform-origin:bottom;}100%{transform:scaleY(0);transform-origin:bottom;}}
@media(max-width:780px){.scroll-cue{display:none;}}

/* ================= TRUST BAR ================= */
#trustbar{background:var(--navy);padding:54px 0;}
.trust-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:30px;}
.trust-item{text-align:center;color:var(--bg);position:relative;padding:0 14px;}
.trust-item:not(:last-child)::after{
  content:'';position:absolute;right:-15px;top:10%;bottom:10%;width:1px;background:rgba(247,245,242,.15);
}
.trust-num{font-family:var(--serif);font-size:clamp(26px,3vw,38px);color:var(--gold);display:block;margin-bottom:6px;}
.trust-label{font-size:12px;letter-spacing:.05em;color:rgba(247,245,242,.75);}
@media(max-width:780px){
  .trust-grid{grid-template-columns:repeat(2,1fr);gap:30px 16px;}
  .trust-item:nth-child(2)::after{display:none;}
}

/* ================= SERVICES ================= */
#services{background:var(--bg);}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line);}
.service-card{
  background:var(--bg);padding:38px 32px;position:relative;
  transition:background .4s var(--ease);
}
.service-card:hover{background:var(--white);}
.service-card .sc-icon{width:38px;height:38px;margin-bottom:22px;color:var(--gold);}
.service-card .sc-icon svg{width:100%;height:100%;}
.service-card h3{font-size:19px;margin-bottom:10px;}
.service-card p{font-size:14px;color:var(--slate);line-height:1.65;}
.service-card .sc-num{position:absolute;top:30px;right:32px;font-family:var(--serif);font-size:13px;color:var(--line);font-weight:500;}
@media(max-width:980px){.services-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:640px){.services-grid{grid-template-columns:1fr;}}

/* ================= SIGNATURE MAKEOVER ================= */
#signature{background:var(--navy);color:var(--bg);overflow:hidden;}
.sig-grid{display:grid;grid-template-columns:1fr 1fr;gap:70px;align-items:center;}
#signature .eyebrow{color:var(--gold-soft);}
#signature h2{color:var(--bg);}
#signature p.lead{color:rgba(247,245,242,.72);}
.sig-list{margin-top:32px;display:flex;flex-direction:column;gap:18px;}
.sig-list li{display:flex;gap:16px;align-items:flex-start;font-size:15px;color:rgba(247,245,242,.85);}
.sig-list svg{width:20px;height:20px;flex-shrink:0;margin-top:2px;color:var(--gold);}
.sig-visual{position:relative;aspect-ratio:1/1;display:flex;align-items:center;justify-content:center;}
.sig-visual svg{width:100%;height:100%;}
@media(max-width:980px){.sig-grid{grid-template-columns:1fr;gap:48px;}.sig-visual{max-width:340px;margin:0 auto;}}

/* ================= PROCESS ================= */
#process{background:var(--bg-deep);}
.process-track{position:relative;margin-top:20px;}
.process-track::before{
  content:'';position:absolute;top:30px;left:0;right:0;height:1px;background:var(--line);
}
.process-steps{display:grid;grid-template-columns:repeat(5,1fr);gap:24px;position:relative;}
.process-step{position:relative;padding-top:0;}
.ps-num{
  width:60px;height:60px;border-radius:50%;background:var(--bg-deep);border:1px solid var(--gold);
  display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-size:20px;color:var(--navy);
  margin-bottom:24px;position:relative;z-index:2;background:var(--bg-deep);
}
.process-step h3{font-size:16.5px;margin-bottom:10px;}
.process-step p{font-size:13.5px;color:var(--slate);line-height:1.6;}
@media(max-width:980px){
  .process-steps{grid-template-columns:1fr;gap:40px;}
  .process-track::before{width:1px;height:100%;left:30px;top:0;right:auto;}
  .process-step{padding-left:90px;}
  .ps-num{position:absolute;left:0;top:-4px;}
}

/* ================= WHY CHOOSE ================= */
#why{background:var(--bg);}
.why-grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:70px;align-items:start;}
.why-visual{position:sticky;top:120px;}
.why-visual .doctor-frame{
  position:relative;border-radius:4px;overflow:hidden;aspect-ratio:3/4;max-width:380px;
  box-shadow:0 30px 70px -30px rgba(11,31,51,.3);
}
.why-visual .doctor-frame img{width:100%;height:100%;object-fit:cover;}
.why-list{display:flex;flex-direction:column;gap:38px;}
.why-row{display:grid;grid-template-columns:64px 1fr;gap:24px;}
.why-row .wr-icon{width:64px;height:64px;border-radius:50%;background:var(--bg-deep);display:flex;align-items:center;justify-content:center;color:var(--gold);}
.why-row .wr-icon svg{width:28px;height:28px;}
.why-row h3{margin-bottom:8px;}
.why-row p{font-size:14.5px;color:var(--slate);line-height:1.7;}
@media(max-width:980px){.why-grid{grid-template-columns:1fr;}.why-visual{position:static;}.why-visual .doctor-frame{margin:0 auto;}}

/* ================= TRANSFORMATION ================= */
#transform{background:var(--navy);color:var(--bg);}
#transform .eyebrow{color:var(--gold-soft);}
#transform h2{color:var(--bg);}
#transform p.lead{color:rgba(247,245,242,.72);}
.transform-wrap{margin-top:54px;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;}
.ba-compare{
  position:relative;width:100%;max-width:420px;aspect-ratio:3/4;margin:0 auto;
  border-radius:4px;overflow:hidden;box-shadow:0 30px 70px -28px rgba(0,0,0,.5);
  cursor:ew-resize;user-select:none;
}
.ba-compare img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:top center;}
.ba-after{z-index:1;}
.ba-before-wrap{position:absolute;inset:0;overflow:hidden;width:55%;z-index:2;border-right:2px solid var(--gold);}
.ba-before-wrap img{width:100%;height:100%;}
.ba-handle{
  position:absolute;top:50%;left:55%;transform:translate(-50%,-50%);
  width:42px;height:42px;border-radius:50%;background:var(--gold);
  display:flex;align-items:center;justify-content:center;z-index:3;
  box-shadow:0 8px 18px rgba(0,0,0,.3);
}
.ba-handle svg{width:18px;height:18px;color:var(--navy);}
.ba-tag{position:absolute;top:16px;z-index:4;font-size:11px;letter-spacing:.12em;text-transform:uppercase;background:rgba(11,31,51,.7);color:#fff;padding:6px 12px;border-radius:2px;}
.ba-tag.before{left:16px;}
.ba-tag.after{right:16px;}
.transform-notes{display:flex;flex-direction:column;gap:24px;}
.tn-item{display:flex;gap:16px;}
.tn-item .tn-dot{width:8px;height:8px;border-radius:50%;background:var(--gold);margin-top:8px;flex-shrink:0;}
.tn-item p{font-size:14.5px;color:rgba(247,245,242,.78);}
.tn-item strong{color:var(--bg);font-weight:600;}
.ba-caption{margin-top:18px;text-align:center;font-size:12px;color:rgba(247,245,242,.55);letter-spacing:.04em;}
@media(max-width:980px){.transform-wrap{grid-template-columns:1fr;gap:40px;}}

/* ================= TECH ================= */
#tech{background:var(--bg);}
.tech-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:30px;}
.tech-card{padding:36px 26px;border:1px solid var(--line);border-radius:4px;text-align:left;transition:transform .4s var(--ease), box-shadow .4s var(--ease);background:var(--white);}
.tech-card:hover{transform:translateY(-6px);box-shadow:0 24px 50px -28px rgba(11,31,51,.25);}
.tech-card .ti{width:34px;height:34px;color:var(--gold);margin-bottom:20px;}
.tech-card .ti svg{width:100%;height:100%;}
.tech-card h3{font-size:17px;margin-bottom:10px;}
.tech-card p{font-size:13.5px;color:var(--slate);line-height:1.6;}
@media(max-width:980px){.tech-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:560px){.tech-grid{grid-template-columns:1fr;}}

/* ================= TESTIMONIALS ================= */
#testimonials{background:var(--bg-deep);overflow:hidden;}
.t-slider{position:relative;max-width:760px;margin:0 auto;}
.t-track{display:flex;transition:transform .6s var(--ease);}
.t-slide{flex:0 0 100%;padding:0 10px;}
.t-card{background:var(--white);border-radius:4px;padding:52px 56px;text-align:center;box-shadow:0 30px 60px -30px rgba(11,31,51,.18);}
.t-stars{display:flex;justify-content:center;gap:4px;margin-bottom:22px;color:var(--gold);}
.t-stars svg{width:16px;height:16px;}
.t-quote{font-family:var(--serif);font-size:21px;line-height:1.55;color:var(--navy);margin-bottom:26px;}
.t-name{font-weight:600;font-size:14px;}
.t-role{font-size:12.5px;color:var(--slate);margin-top:3px;}
.t-nav{display:flex;justify-content:center;gap:10px;margin-top:34px;}
.t-dot{width:8px;height:8px;border-radius:50%;background:var(--line);cursor:pointer;transition:.3s;}
.t-dot.active{background:var(--gold);width:24px;border-radius:4px;}
@media(max-width:640px){.t-card{padding:38px 26px;}.t-quote{font-size:18px;}}

/* ================= FAQ ================= */
#faq{background:var(--bg);}
.faq-list{max-width:780px;}
.faq-item{border-bottom:1px solid var(--line);}
.faq-q{
  display:flex;justify-content:space-between;align-items:center;gap:20px;
  padding:26px 0;cursor:pointer;font-weight:500;font-size:16.5px;font-family:var(--serif);
}
.faq-q .fq-icon{width:18px;height:18px;flex-shrink:0;position:relative;}
.faq-q .fq-icon::before,.faq-q .fq-icon::after{
  content:'';position:absolute;background:var(--navy);transition:.35s var(--ease);
}
.faq-q .fq-icon::before{width:100%;height:1.4px;top:50%;left:0;transform:translateY(-50%);}
.faq-q .fq-icon::after{width:1.4px;height:100%;left:50%;top:0;transform:translateX(-50%);}
.faq-item.open .fq-icon::after{transform:translateX(-50%) rotate(90deg);opacity:0;}
.faq-a{max-height:0;overflow:hidden;transition:max-height .45s var(--ease);}
.faq-a p{padding-bottom:26px;font-size:14.5px;color:var(--slate);line-height:1.75;max-width:680px;}

/* ================= LOCATION ================= */
#location{background:var(--navy);color:var(--bg);}
#location .eyebrow{color:var(--gold-soft);}
#location h2{color:var(--bg);}
.loc-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;}
.loc-info{display:flex;flex-direction:column;gap:26px;}
.loc-row{display:flex;gap:18px;align-items:flex-start;}
.loc-row svg{width:22px;height:22px;color:var(--gold);flex-shrink:0;margin-top:3px;}
.loc-row h3{font-size:15px;color:var(--gold-soft);font-family:var(--sans);font-weight:600;letter-spacing:.04em;text-transform:uppercase;margin-bottom:6px;}
.loc-row p,.loc-row a{font-size:15.5px;color:rgba(247,245,242,.85);}
.loc-map{
  aspect-ratio:4/3;border-radius:4px;overflow:hidden;border:1px solid rgba(247,245,242,.15);
}
.loc-map iframe{width:100%;height:100%;border:0;filter:grayscale(.2) contrast(1.05);}
@media(max-width:980px){.loc-grid{grid-template-columns:1fr;gap:40px;}}

/* ================= CONVERSION CTA ================= */
#cta-final{
  background:linear-gradient(120deg, var(--navy), var(--navy-soft));
  color:var(--bg);text-align:center;position:relative;overflow:hidden;
}
#cta-final .smile-deco{opacity:.18;}
.cta-inner{position:relative;z-index:2;max-width:680px;margin:0 auto;}
#cta-final .eyebrow{justify-content:center;color:var(--gold-soft);}
#cta-final .eyebrow::before{display:none;}
#cta-final h2{color:var(--bg);margin-bottom:20px;}
#cta-final p.lead{color:rgba(247,245,242,.75);margin:0 auto 40px;text-align:center;}
.cta-btns{display:flex;justify-content:center;gap:16px;flex-wrap:wrap;}

/* lead form */
.lead-form{
  margin-top:54px;background:rgba(247,245,242,.06);border:1px solid rgba(247,245,242,.15);
  border-radius:6px;padding:40px;text-align:left;backdrop-filter:blur(6px);
}
.lead-form h3{color:var(--bg);font-size:20px;margin-bottom:6px;}
.lead-form p{color:rgba(247,245,242,.65);font-size:13.5px;margin-bottom:26px;}
.lf-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;}
.lf-field{display:flex;flex-direction:column;gap:8px;}
.lf-field label{font-size:11.5px;letter-spacing:.06em;text-transform:uppercase;color:rgba(247,245,242,.55);}
.lf-field input,.lf-field textarea,.lf-field select{
  background:rgba(247,245,242,.08);border:1px solid rgba(247,245,242,.2);border-radius:3px;
  padding:13px 14px;color:var(--bg);font-family:var(--sans);font-size:14.5px;
  transition:border-color .3s;
}
.lf-field input:focus,.lf-field textarea:focus,.lf-field select:focus{border-color:var(--gold);outline:none;}
.lf-field input::placeholder,.lf-field textarea::placeholder{color:rgba(247,245,242,.35);}
.lead-form .full{grid-column:1/-1;}
.lf-submit{margin-top:8px;width:100%;justify-content:center;}
.lf-success{display:none;text-align:center;padding:30px 0;}
.lf-success.show{display:block;}
.lf-success svg{width:48px;height:48px;color:var(--gold);margin:0 auto 16px;}
.lf-success h3{margin-bottom:8px;}
.lf-success p{color:rgba(247,245,242,.7);}
@media(max-width:640px){.lf-row{grid-template-columns:1fr;}.lead-form{padding:28px 22px;}}

/* ================= FOOTER ================= */
footer{background:#081623;color:rgba(247,245,242,.8);padding:90px 0 0;}
.footer-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:50px;padding-bottom:60px;border-bottom:1px solid rgba(247,245,242,.1);}
.footer-brand{display:flex;align-items:center;gap:10px;font-family:var(--serif);font-size:20px;color:var(--bg);margin-bottom:18px;}
.footer-brand svg{width:30px;height:30px;}
.footer-grid p{font-size:13.5px;line-height:1.8;color:rgba(247,245,242,.55);max-width:280px;}
.footer-col h4{font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--gold-soft);margin-bottom:20px;}
.footer-col ul{display:flex;flex-direction:column;gap:13px;}
.footer-col a{font-size:14px;color:rgba(247,245,242,.7);transition:color .25s;}
.footer-col a:hover{color:var(--gold);}
.footer-social{display:flex;gap:14px;margin-top:22px;}
.footer-social a{width:38px;height:38px;border:1px solid rgba(247,245,242,.18);border-radius:50%;display:flex;align-items:center;justify-content:center;transition:.3s;}
.footer-social a:hover{background:var(--gold);border-color:var(--gold);color:var(--navy);}
.footer-social svg{width:16px;height:16px;}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;padding:26px 0;font-size:12.5px;color:rgba(247,245,242,.45);flex-wrap:wrap;gap:12px;}
.footer-bottom a{color:rgba(247,245,242,.45);}
.footer-bottom a:hover{color:var(--gold);}
@media(max-width:880px){.footer-grid{grid-template-columns:1fr 1fr;gap:40px;}}
@media(max-width:560px){.footer-grid{grid-template-columns:1fr;}}

/* ================= FLOATING CTA / STICKY ================= */
#float-consult{
  position:fixed;bottom:30px;right:30px;z-index:850;
  display:flex;align-items:center;gap:10px;padding:16px 24px;
  background:var(--navy);color:var(--bg);border-radius:50px;
  box-shadow:0 18px 40px -14px rgba(11,31,51,.5);
  transform:translateY(140%);transition:transform .5s var(--ease);
  font-size:13.5px;font-weight:600;
}
#float-consult.show{transform:translateY(0);}
#float-consult svg{width:18px;height:18px;color:var(--gold);}
#float-consult:hover{background:var(--navy-soft);}
@media(max-width:780px){#float-consult{display:none;}}

#sticky-mobile{
  position:fixed;bottom:0;left:0;right:0;z-index:880;
  display:none;background:var(--navy);padding:12px 16px;
  box-shadow:0 -8px 24px rgba(0,0,0,.18);
  gap:10px;
}
#sticky-mobile a{
  flex:1;display:flex;align-items:center;justify-content:center;gap:8px;
  padding:13px 10px;border-radius:3px;font-size:13px;font-weight:600;
}
#sticky-mobile .sm-call{background:rgba(247,245,242,.12);color:var(--bg);}
#sticky-mobile .sm-consult{background:var(--gold);color:var(--navy);}
@media(max-width:780px){#sticky-mobile{display:flex;}body{padding-bottom:70px;}}

/* ================= EXIT MODAL ================= */
#exit-modal{
  position:fixed;inset:0;background:rgba(11,31,51,.7);z-index:1200;
  display:flex;align-items:center;justify-content:center;padding:24px;
  opacity:0;visibility:hidden;transition:opacity .4s var(--ease), visibility .4s var(--ease);
}
#exit-modal.show{opacity:1;visibility:visible;}
.exit-card{
  background:var(--bg);max-width:480px;width:100%;border-radius:6px;padding:50px 44px;
  position:relative;text-align:center;transform:scale(.92);transition:transform .4s var(--ease);
  box-shadow:0 50px 100px -30px rgba(0,0,0,.4);
}
#exit-modal.show .exit-card{transform:scale(1);}
.exit-close{position:absolute;top:18px;right:18px;width:32px;height:32px;display:flex;align-items:center;justify-content:center;color:var(--slate);}
.exit-close svg{width:18px;height:18px;}
.exit-card .eyebrow{justify-content:center;}
.exit-card .eyebrow::before{display:none;}
.exit-card h3{font-size:26px;margin-bottom:14px;}
.exit-card p{color:var(--slate);font-size:14.5px;margin-bottom:28px;}
.exit-form{display:flex;flex-direction:column;gap:12px;}
.exit-form input{
  padding:14px 16px;border:1px solid var(--line);border-radius:3px;font-size:14.5px;font-family:var(--sans);
}
.exit-form input:focus{outline:2px solid var(--gold);border-color:var(--gold);}

/* skip link */
.skip-link{position:absolute;left:-999px;top:0;background:var(--navy);color:#fff;padding:10px 16px;z-index:2000;}
.skip-link:focus{left:10px;top:10px;}
</style>
